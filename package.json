{
  "name": "tribe-challenge-tracker",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@capacitor-firebase/authentication": "^6.3.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "capacitor-health": "^0.0.14",
    "firebase": "^12.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "prebuild": "node scripts/check-build-runtime.js",
    "build": "node scripts/run-react-build-with-timeout.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:parity": "react-scripts test --runTestsByPath src/__tests__/crossPlatformParity.test.js src/__tests__/crossPlatformParity.storeLaunch.test.js src/__tests__/crossPlatformParity.storeLaunchDecision.test.js src/__tests__/crossPlatformParity.storePolicy.test.js src/__tests__/crossPlatformParity.storeReview.test.js src/__tests__/crossPlatformParity.storeReviewPlanning.test.js src/__tests__/crossPlatformParity.storeEvidence.test.js src/__tests__/crossPlatformParity.creatorHosting.test.js src/__tests__/crossPlatformParity.creatorHostingReadiness.test.js src/__tests__/crossPlatformParity.creatorHostingReplies.test.js src/__tests__/crossPlatformParity.creatorHostingApplicationReview.test.js src/__tests__/crossPlatformParity.communityLaunch.test.js src/__tests__/crossPlatformParity.communityContent.test.js src/__tests__/crossPlatformParity.communityExperiments.test.js src/__tests__/crossPlatformParity.challengePacks.test.js src/__tests__/crossPlatformParity.supportBilling.test.js src/__tests__/crossPlatformParity.entitlementRecoveryReview.test.js src/__tests__/crossPlatformParity.subscriptionLifecycle.test.js src/__tests__/crossPlatformParity.monetizationLaunch.test.js src/__tests__/crossPlatformParity.monetizationValueKits.test.js src/__tests__/crossPlatformParity.communityValueKits.test.js src/__tests__/crossPlatformParity.supportAccount.test.js src/__tests__/crossPlatformParity.supportRequests.test.js src/__tests__/crossPlatformParity.featureSubmissions.test.js src/__tests__/crossPlatformParity.proProfile.test.js src/__tests__/crossPlatformParity.communityEventInterest.test.js src/__tests__/crossPlatformParity.partnerPerks.test.js src/__tests__/crossPlatformParity.partnerPerkClaimReview.test.js src/__tests__/crossPlatformParity.partnerPerkDecisionCopy.test.js src/__tests__/crossPlatformParity.partnerPerkFulfillment.test.js src/__tests__/crossPlatformParity.partnerCampaigns.test.js src/__tests__/crossPlatformParity.partnerCampaignDecisions.test.js src/__tests__/crossPlatformParity.partnerCampaignApplications.test.js src/__tests__/crossPlatformParity.referralRewards.test.js src/__tests__/crossPlatformParity.weeklyCampaignArchitecture.test.js src/__tests__/crossPlatformParity.weeklyCampaignCore.test.js src/__tests__/crossPlatformParity.weeklyCampaignReviewPlanning.test.js src/__tests__/crossPlatformParity.weeklyCampaignResponses.test.js src/__tests__/crossPlatformParity.weeklyCampaignStories.test.js src/__tests__/crossPlatformParity.weeklyCampaignStoryFollowUp.test.js src/__tests__/crossPlatformParity.weeklyCampaignStoryRecaps.test.js src/__tests__/crossPlatformParity.weeklyCampaignEngagement.test.js src/__tests__/crossPlatformParity.weeklyCampaignLiveContent.test.js src/__tests__/crossPlatformParity.weeklyCampaignContentBank.test.js src/__tests__/crossPlatformParity.weeklyCampaignCollab.test.js src/__tests__/crossPlatformParity.weeklyCampaignCollabLifecycle.test.js src/__tests__/crossPlatformParity.weeklyCampaignFollowUp.test.js --watchAll=false --runInBand",
    "test:store-readiness": "react-scripts test --runTestsByPath src/__tests__/storeLaunchReadinessScript.test.js --watchAll=false --runInBand",
    "test:purchase-entitlements": "react-scripts test --runTestsByPath src/__tests__/purchaseEntitlements.test.js src/__tests__/purchaseValidationReadiness.test.js --watchAll=false --runInBand",
    "test:badges": "react-scripts test --runTestsByPath src/__tests__/badgeCatalog.test.js src/__tests__/badgeService.test.js src/__tests__/badgeProgress.test.js --watchAll=false --runInBand",
    "test:challenge-templates": "react-scripts test --runTestsByPath src/__tests__/challengeTemplates.test.js --watchAll=false --runInBand",
    "test:campaign-share": "react-scripts test --runTestsByPath src/__tests__/challengeShare.test.js --watchAll=false --runInBand",
    "test:monetization-model": "react-scripts test --runTestsByPath src/__tests__/monetizationModel.test.js src/__tests__/partnerPerksProps.test.js --watchAll=false --runInBand",
    "test:engagement-copy": "react-scripts test --runTestsByPath src/__tests__/engagementCopy.test.js src/__tests__/monetizationPreLaunchCopy.test.js --watchAll=false --runInBand",
    "test:referral-copy": "react-scripts test --runTestsByPath src/__tests__/referralCopy.test.js src/__tests__/referralRewardSocialProofCopy.test.js src/__tests__/referralRewardDecisionCopy.test.js --watchAll=false --runInBand",
    "test:support-billing-copy": "react-scripts test --runTestsByPath src/__tests__/supportBillingCopy.test.js src/__tests__/storeBillingSupportCopy.test.js src/__tests__/storeLifecycleCopy.test.js --watchAll=false --runInBand",
    "test:creator-partner-copy": "react-scripts test --runTestsByPath src/__tests__/creatorPartnerCopy.test.js src/__tests__/partnerMonetizationCopy.test.js --watchAll=false --runInBand",
    "test:build-wrapper": "node scripts/verify-react-build-timeout.js",
    "test:build-runtime": "react-scripts test --runTestsByPath src/__tests__/buildRuntimeGuard.test.js --watchAll=false --runInBand",
    "test:release-audit": "react-scripts test --runTestsByPath src/__tests__/monetizationReleaseAuditScript.test.js --watchAll=false --runInBand",
    "test:release": "node scripts/verify-release.js && npm run test:store-readiness && npm run test:purchase-entitlements && npm run test:badges && npm run test:challenge-templates && npm run test:campaign-share && npm run test:profile-share && npm run test:weekly-campaign && npm run test:monetization-model && npm run test:engagement-copy && npm run test:referral-copy && npm run test:support-billing-copy && npm run test:creator-partner-copy && npm run test:build-wrapper && npm run test:build-runtime && npm run test:release-audit && npm run test:parity",
    "store:readiness": "node scripts/check-store-launch-readiness.js",
    "release:audit": "node scripts/write-monetization-release-audit.js",
    "release:check": "npm test -- --watchAll=false && npm run build && npm run test:release",
    "native:ios:build": "xcodebuild -project ../TribeChallengeTrackerIOS/TribeChallenge.xcodeproj -scheme TribeChallenge -destination 'generic/platform=iOS Simulator' -derivedDataPath /private/tmp/TribeChallengeDerivedData -clonedSourcePackagesDirPath /private/tmp/TribeChallengeSPM build",
    "native:android:build": "cd ../TribeChallengeTrackerAndroid && JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" ./gradlew assembleDebug",
    "release:check:all": "npm run release:check && npm run native:ios:build && npm run native:android:build",
    "release:check:all:audit": "npm run release:check:all && npm run release:audit",
    "app-links:android": "node scripts/write-assetlinks.js",
    "hosting:release": "npm run app-links:android && npm run build && firebase deploy --only hosting",
    "cap:sync": "npm run build && npx cap sync && node scripts/patch-native-plugins.js",
    "cap:ios": "npm run build && npx cap sync ios && node scripts/patch-native-plugins.js && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "test:profile-share": "react-scripts test --runTestsByPath src/__tests__/profileShareCards.test.js src/__tests__/profileShareCardSharing.test.js --watchAll=false --runInBand",
    "test:weekly-campaign": "react-scripts test --runTestsByPath src/__tests__/weeklyCampaignDerivedData.test.js src/__tests__/weeklyCampaignMarketingProps.test.js --watchAll=false --runInBand"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
