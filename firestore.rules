        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "manualReviewOnly", "chargesUsers", "unlocksPaidAccess", "writesEntitlements", "createsDiscounts", "isPaidAccessLive", "promotesPaidFeatures", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /weeklyCampaignReviews/{reviewId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsAttribution == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.keys().hasAll(["uid", "campaignName", "campaignWeek", "campaignHashtag", "recommendedExperimentLabel", "campaignReach", "referralJoins", "featureSubmissionCount", "status", "manualReviewOnly", "createsAttribution", "hasTrackingPixels", "isPaidAccessLive"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsAttribution == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "manualReviewOnly", "createsAttribution", "hasTrackingPixels", "isPaidAccessLive", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Partner campaign applications ────────────────────────────────────────
    // Members can request manual sponsor-pilot review from first-party demand.
    // Admins can use reviewPartnerCampaignApplication to update reviewNote,
    // reviewedBy, reviewedAt, and status. This queue does not create ads,
    // tracking, partner links, purchases, or entitlements.
    match /partnerCampaignApplications/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && (
          request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "topPerkId", "topPerkLabel", "demandCount", "totalDemand", "campaignReach", "referralJoins", "status"])
          && request.resource.data.demandCount >= 0
          && request.resource.data.totalDemand >= 0
          && request.resource.data.campaignReach >= 0
          && request.resource.data.referralJoins >= 0
      );
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        ) ||
        (
          request.auth.uid == uid
          && resource.data.status == "open"
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "topPerkId", "topPerkLabel", "demandCount", "totalDemand", "campaignReach", "referralJoins", "status"])
          && request.resource.data.demandCount >= 0
          && request.resource.data.totalDemand >= 0
          && request.resource.data.campaignReach >= 0
          && request.resource.data.referralJoins >= 0
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Partner campaign retrospective reviews ─────────────────────────────
    // Admin-only aggregate post-pilot evidence. These records must not create
    // partner links, tracking, payouts, coupons, purchases, entitlements,
    // revenue-share, third-party exports, fulfillment promises, or messages.
    match /partnerCampaignRetrospectiveReviews/{reviewId} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null && isAdmin()
        && request.resource.data.status == "open"
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.aggregateOnly == true
        && request.resource.data.createsPartnerLinks == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.usesAdTargeting == false
        && request.resource.data.createsAffiliatePayouts == false
        && request.resource.data.createsCommissions == false
        && request.resource.data.createsCoupons == false
        && request.resource.data.createsDiscounts == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.startsRevenueShare == false
        && request.resource.data.makesPaidAccessClaims == false
        && request.resource.data.exportsThirdPartyData == false
        && request.resource.data.collectsPayment == false
        && request.resource.data.promisesFulfillment == false
        && request.resource.data.promisesOutcomes == false
        && request.resource.data.impliesMedicalResults == false
        && request.resource.data.autoMessagesUsers == false
        && request.resource.data.scrapesMessages == false
        && request.resource.data.pressuresPartnersOrMembers == false;
      allow update: if request.auth != null && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.aggregateOnly == true
        && request.resource.data.createsPartnerLinks == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.usesAdTargeting == false
        && request.resource.data.createsAffiliatePayouts == false
        && request.resource.data.createsCommissions == false
        && request.resource.data.createsCoupons == false
        && request.resource.data.createsDiscounts == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.startsRevenueShare == false
        && request.resource.data.makesPaidAccessClaims == false
        && request.resource.data.exportsThirdPartyData == false
        && request.resource.data.collectsPayment == false
        && request.resource.data.promisesFulfillment == false
        && request.resource.data.promisesOutcomes == false
        && request.resource.data.impliesMedicalResults == false
        && request.resource.data.autoMessagesUsers == false
        && request.resource.data.scrapesMessages == false
        && request.resource.data.pressuresPartnersOrMembers == false;
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Partner perk claims ─────────────────────────────────────────────────
    // Eligible members can request manual perk review. Admins can use
    // reviewPartnerPerkClaim to update review status plus reviewNote,
    // reviewedBy, and reviewedAt. This queue does not create coupons, partner
    // links, payouts, discounts, purchases, or entitlements.
    match /partnerPerkClaims/{claimId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (
          request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "perkId", "perkLabel", "current", "target", "status"])
          && ["gear", "recovery", "nutrition"].hasAny([request.resource.data.perkId])
          && request.resource.data.current >= request.resource.data.target
          && request.resource.data.target > 0
      );
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        ) ||
        (
          resource.data.uid == request.auth.uid
          && resource.data.status == "open"
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "perkId", "perkLabel", "current", "target", "status"])
          && ["gear", "recovery", "nutrition"].hasAny([request.resource.data.perkId])
          && request.resource.data.current >= request.resource.data.target
          && request.resource.data.target > 0
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Partner perk handoff audit reviews ──────────────────────────────────
    // Manual aggregate evidence only after partner perk claim review. These
    // records must not create coupons, links, payouts, discounts, purchases,
    // entitlements, tracking, refunds, fulfillment promises, or messages.
    match /partnerPerkHandoffAuditReviews/{reviewId} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null && isAdmin()
        && request.resource.data.status == "open"
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsCoupons == false
        && request.resource.data.createsPartnerLinks == false
        && request.resource.data.createsPayouts == false
        && request.resource.data.createsDiscounts == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.createsAffiliateRewards == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.usesAdTargeting == false
        && request.resource.data.exportsThirdPartyData == false
        && request.resource.data.makesPaidAccessClaims == false
        && request.resource.data.collectsPayment == false
        && request.resource.data.processesRefunds == false
        && request.resource.data.promisesFulfillment == false
        && request.resource.data.autoMessagesUsers == false
        && request.resource.data.scrapesMessages == false
        && request.resource.data.pressuresMembers == false;
      allow update: if request.auth != null && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsCoupons == false
        && request.resource.data.createsPartnerLinks == false
        && request.resource.data.createsPayouts == false
        && request.resource.data.createsDiscounts == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.createsAffiliateRewards == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.usesAdTargeting == false
        && request.resource.data.exportsThirdPartyData == false
        && request.resource.data.makesPaidAccessClaims == false
        && request.resource.data.collectsPayment == false
        && request.resource.data.processesRefunds == false
        && request.resource.data.promisesFulfillment == false
        && request.resource.data.autoMessagesUsers == false
        && request.resource.data.scrapesMessages == false
        && request.resource.data.pressuresMembers == false;
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Challenges ────────────────────────────────────────────────────────────
    // Any authenticated user can read challenges (for invite-link joins).
    // Only the creator can update/delete; admins can do anything.
    match /challenges/{challengeId} {
      function isChallengeMember() {
        return exists(/databases/$(database)/documents/challenges/$(challengeId)/members/$(request.auth.uid));
      }

      function isChallengeOwner() {
        return get(/databases/$(database)/documents/challenges/$(challengeId)).data.createdBy == request.auth.uid;
      }

      function isChallengeAdmin() {
        return isAdmin() ||
          isChallengeOwner() ||
          (
            isChallengeMember() &&
            get(/databases/$(database)/documents/challenges/$(challengeId)/members/$(request.auth.uid)).data.role == "admin"
          );
      }

      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.createdBy ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
      );
      allow delete: if request.auth != null && (
        isAdmin() || request.auth.uid == resource.data.createdBy
      );

      // Members subcollection
      match /members/{uid} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == uid;

        // FIX: split create and update so we can add the admin-promotion rule.
        // A member can always update their own doc.
        // The challenge creator can also update another member's doc, but only
        // to change the 'role' field — used when promoting a new admin on leave.
        allow update: if request.auth != null && (
          request.auth.uid == uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']) &&
            get(/databases/$(database)/documents/challenges/$(challengeId)).data.createdBy == request.auth.uid
          )
        );

        allow delete: if request.auth != null && (
          request.auth.uid == uid || isAdmin()
        );

        // Daily progress logs — only the member writes; anyone authenticated can read
        match /dailyLogs/{date} {
          allow read:  if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == uid;
        }
      }

      // Challenge updates — admins can post announcements/reminders. Custom
      // challenges can also enable plain member messages without push delivery.
      match /messages/{messageId} {
        allow read: if request.auth != null && (isChallengeMember() || isChallengeOwner() || isAdmin());
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.challengeId == challengeId
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 280
          && request.resource.data.notificationSent == false
          && (
            (
              isChallengeAdmin()
              && ["announcement", "log_reminder"].hasAny([request.resource.data.type])
              && request.resource.data.notificationRequested == true
            ) ||
            (
              isChallengeMember()
              && request.resource.data.type == "member_message"
              && request.resource.data.notificationRequested == false
              && get(/databases/$(database)/documents/challenges/$(challengeId)).data.community.memberMessagesEnabled == true
            )
          );
        allow update: if false;
        allow delete: if request.auth != null && isChallengeAdmin();
      }
    }
  }
}
