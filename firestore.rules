rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super admin check ─────────────────────────────────────────────────────
    // A document at /admins/{uid} marks that user as a super admin.
    // Super admins can read every collection — needed for future admin dashboards.
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFollowerOf(ownerUid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(ownerUid)/followers/$(request.auth.uid));
    }

    function hasBlocked(leftUid, rightUid) {
      return exists(/databases/$(database)/documents/users/$(leftUid)/blockedUsers/$(rightUid));
    }

    function noBlockBetween(ownerUid) {
      return isSignedIn()
        && !hasBlocked(request.auth.uid, ownerUid)
        && !hasBlocked(ownerUid, request.auth.uid);
    }

    function hasWorkoutOwner(data) {
      return data.ownerUid is string && data.ownerUid.size() > 0;
    }

    // ── Admins collection ─────────────────────────────────────────────────────
    // Only existing admins can read or write this collection.
    match /admins/{uid} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── Published app configuration / lightweight CMS ────────────────────────
    // Signed-in apps can read rank rules. Only /admins/{uid} users can publish
    // changes from the web admin CMS.
    match /appConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users read/write their own doc; admins can read all and can update the
    // mirrored accountDeletionRequest review status only.
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
        && isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["accountDeletionRequest"]);

      // Activity log — one doc per day, written and read only by the owner.
      // FIX: was missing, causing getActivityLog / saveActivity to fail.
      match /activityLog/{dateStr} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Training journal — detailed gym/run/yoga performance logs owned by the user.
      match /trainingSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Trusted exercise PR summaries. Members can read their own PRs; writes
      // are handled by Cloud Functions with Admin SDK privileges or admins.
      match /exercisePRs/{exerciseId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if request.auth != null && isAdmin();
      }

      // Earned badges — set when badges are awarded; read by the owner.
      // FIX: was missing, causing loadEarnedBadges / awardBadges to fail.
      match /earnedBadges/{badgeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Challenge completion keepsakes — one durable recap per finished challenge.
      match /challengeCompletions/{challengeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // FCM device tokens — owned by the signed-in user. Cloud Functions read
      // these with Admin SDK privileges when challenge admins send updates.
      match /deviceTokens/{tokenId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.token == tokenId
          && request.resource.data.enabled == true
          && ["ios", "android", "web"].hasAny([request.resource.data.platform]);
        allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      // Blocked users - owned by the signed-in user. Apps use this to hide
      // community feed entries, challenge messages, and leaderboard members.
      match /blockedUsers/{blockedUid} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == uid;
      }

      // People this user follows. The signed-in owner controls only their own
      // following list; this keeps the social graph opt-in and reversible.
      match /following/{targetUid} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.targetUid == targetUid
          && request.resource.data.status == "following";
        allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      // People following this user. A signed-in member can create/remove only
      // their own follower edge on another user's profile.
      match /followers/{followerUid} {
        allow read: if request.auth != null && (request.auth.uid == uid || request.auth.uid == followerUid || isAdmin());
        allow create, update: if request.auth != null
          && request.auth.uid == followerUid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.followerUid == followerUid
          && request.resource.data.targetUid == uid
          && request.resource.data.status == "following";
        allow delete: if request.auth != null && (request.auth.uid == followerUid || request.auth.uid == uid || isAdmin());
      }
    }

    // ── Public/follower profile discovery ─────────────────────────────────
    // Users publish a small profile card separate from private account data.
    // Public cards can be discovered by signed-in members; follower-only cards
    // are readable by the owner, admins, or existing followers.
    match /publicProfiles/{uid} {
      allow read: if request.auth != null
        && (
          resource.data.profileVisibility == "public"
          || request.auth.uid == uid
          || isAdmin()
          || (
            resource.data.profileVisibility == "followers"
            && exists(/databases/$(database)/documents/users/$(uid)/followers/$(request.auth.uid))
          )
        );
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && ["public", "followers", "private"].hasAny([request.resource.data.profileVisibility])
        && ["public", "followers", "private"].hasAny([request.resource.data.routineDefaultVisibility]);
      allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // ── Public routine library for the follow beta ─────────────────────────
    // Training sessions remain private under /users/{uid}/trainingSessions.
    // This collection stores only routines a member explicitly shares.
    match /publicRoutines/{routineId} {
      allow read: if request.auth != null
        && hasWorkoutOwner(resource.data)
        && (
          resource.data.ownerUid == request.auth.uid
          || isAdmin()
          || (
            noBlockBetween(resource.data.ownerUid)
            && resource.data.visibility == "public"
          )
          || (
            noBlockBetween(resource.data.ownerUid)
            && resource.data.visibility == "followers"
            && isFollowerOf(resource.data.ownerUid)
          )
        );
      allow create, update: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && ["public", "followers", "private"].hasAny([request.resource.data.visibility]);
      allow delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ── Workouts backend-driven catalog and social foundation ───────────────
    // Official exercise content is backend/admin-authored. Clients can read
    // only published exercises; draft and archived content stay admin-only.
    match /exerciseCatalog/{exerciseId} {
      allow read: if request.auth != null
        && (resource.data.status == "published" || isAdmin());
      allow create, update: if request.auth != null
        && isAdmin()
        && request.resource.data.id == exerciseId
        && ["draft", "published", "archived"].hasAny([request.resource.data.status])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && request.resource.data.primaryMuscles is list
        && request.resource.data.equipment is list
        && ["beginner", "intermediate", "advanced"].hasAny([request.resource.data.level])
        && ["push", "pull", "squat", "hinge", "carry", "core", "cardio", "mobility"].hasAny([request.resource.data.movementPattern]);
      allow delete: if request.auth != null && isAdmin();
    }

    // Workout templates cover official/user-authored reusable workouts. Phase
    // 1 uses this as backend foundation; production clients should still save
    // completed sessions under users/{uid}/trainingSessions.
    match /workoutTemplates/{templateId} {
      allow read: if request.auth != null
        && (
          isAdmin()
          || (
            resource.data.status == "published"
            && resource.data.visibility == "system"
          )
          || (
            hasWorkoutOwner(resource.data)
            && resource.data.ownerUid == request.auth.uid
          )
          || (
            hasWorkoutOwner(resource.data)
            && noBlockBetween(resource.data.ownerUid)
            && resource.data.status == "published"
            && resource.data.visibility == "public"
          )
          || (
            hasWorkoutOwner(resource.data)
            && noBlockBetween(resource.data.ownerUid)
            && resource.data.status == "published"
            && resource.data.visibility == "tribe"
            && isFollowerOf(resource.data.ownerUid)
          )
        );
      allow create: if request.auth != null
        && (
          (
            isAdmin()
            && ["draft", "published", "archived"].hasAny([request.resource.data.status])
            && ["system", "public", "tribe", "private"].hasAny([request.resource.data.visibility])
          )
          || (
            request.resource.data.ownerUid == request.auth.uid
            && ["draft", "published", "archived"].hasAny([request.resource.data.status])
            && ["public", "tribe", "private"].hasAny([request.resource.data.visibility])
          )
        );
      allow update: if request.auth != null
        && (
          (
            isAdmin()
            && ["draft", "published", "archived"].hasAny([request.resource.data.status])
            && ["system", "public", "tribe", "private"].hasAny([request.resource.data.visibility])
          )
          || (
            resource.data.ownerUid == request.auth.uid
            && request.resource.data.ownerUid == request.auth.uid
            && ["draft", "published", "archived"].hasAny([request.resource.data.status])
            && ["public", "tribe", "private"].hasAny([request.resource.data.visibility])
          )
        );
      allow delete: if request.auth != null
        && (isAdmin() || resource.data.ownerUid == request.auth.uid);
    }

    // Completed workout shares are sanitized mirrors of private training
    // sessions. They enforce public/tribe visibility and bidirectional blocks
    // at the rules layer so direct Firestore reads cannot bypass blocking.
    match /publicWorkouts/{publicWorkoutId} {
      allow read: if request.auth != null
        && hasWorkoutOwner(resource.data)
        && (
          resource.data.ownerUid == request.auth.uid
          || isAdmin()
          || (
            noBlockBetween(resource.data.ownerUid)
            && resource.data.visibility == "public"
          )
          || (
            noBlockBetween(resource.data.ownerUid)
            && resource.data.visibility == "tribe"
            && isFollowerOf(resource.data.ownerUid)
          )
        );
      allow create, update: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && ["public", "tribe"].hasAny([request.resource.data.visibility])
        && request.resource.data.sourceSessionId is string
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/trainingSessions/$(request.resource.data.sourceSessionId))
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120;
      allow delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ── Tribe activity feed ─────────────────────────────────────────────────
    // Authenticated members can read the shared feed. A member can create and
    // remove only their own feed rows, which mirror activity logs.
    match /tribeFeed/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["reactionCounts", "reactionUsers", "reactionTotal", "lastReactionAt"])
        && request.resource.data.reactionTotal is int
        && request.resource.data.reactionTotal >= 0
        && request.resource.data.reactionTotal <= 100000
        && request.resource.data.lastReactionAt == request.time;
      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ── Account deletion requests ────────────────────────────────────────────
    // Users can record their own support-reviewed deletion request. Admins can
    // use reviewAccountDeletionRequest to update reviewNote, reviewedBy,
    // reviewedAt, and status. The app does not directly delete auth accounts,
    // purchase records, subscriptions, refunds, or marketplace data.
    match /accountDeletionRequests/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update: if request.auth != null
        && (
          (
            request.auth.uid == uid
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.status == "requested"
          )
          || (
            isAdmin()
            && ["requested", "contacted", "verified", "blocked", "closed"].hasAny([request.resource.data.status])
          )
        );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Support requests ─────────────────────────────────────────────────────
    // Users can create support messages for their own account. Admins can use
    // reviewSupportRequest to update reviewNote, reviewedBy, reviewedAt, and
    // status outside destructive account, refund, subscription, or entitlement
    // actions.
    match /supportRequests/{requestId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["uid", "category", "message", "status"])
        && ["general", "account", "billing", "bug", "safety"].hasAny([request.resource.data.category]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "waiting", "resolved", "closed"].hasAny([request.resource.data.status]);
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Community safety reports ───────────────────────────────────────────
    // Members can report visible community content. Admins review the queue
    // separately; client apps do not moderate or delete other users' content.
    match /contentReports/{reportId} {
      allow read: if request.auth != null && (resource.data.reporterUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["reporterUid", "contentType", "contentId", "reason", "status", "source"])
        && ["tribe_feed", "challenge_message", "challenge_member", "profile"].hasAny([request.resource.data.contentType])
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 3
        && request.resource.data.reason.size() <= 500;
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "reviewing", "resolved", "dismissed"].hasAny([request.resource.data.status]);
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Entitlement recovery requests ───────────────────────────────────────
    // Members can ask support to review missing purchase entitlements after
    // restore/sync. Admins can use reviewEntitlementRecoveryRequest to update
    // reviewNote, reviewedBy, reviewedAt, and status. This never grants access,
    // refunds, subscriptions, purchase records, or marketplace bypasses.
    match /entitlementRecoveryRequests/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && (
          request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "productCount", "proActive", "packCount", "activePackCount", "reason", "status"])
          && request.resource.data.productCount >= 0
          && request.resource.data.packCount >= 0
          && request.resource.data.activePackCount >= 0
          && ["restore_sync_failed", "missing_pro", "missing_pack", "account_mismatch", "billing_question"].hasAny([request.resource.data.reason])
      );
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "waiting", "resolved", "closed"].hasAny([request.resource.data.status])
        ) ||
        (
          request.auth.uid == uid
          && resource.data.status == "open"
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "productCount", "proActive", "packCount", "activePackCount", "reason", "status"])
          && request.resource.data.productCount >= 0
          && request.resource.data.packCount >= 0
          && request.resource.data.activePackCount >= 0
          && ["restore_sync_failed", "missing_pro", "missing_pack", "account_mismatch", "billing_question"].hasAny([request.resource.data.reason])
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Store test purchase evidence ────────────────────────────────────────
    // Admin-only sandbox/license-test QA evidence. Admins can use
    // reviewStoreTestPurchaseEvidence to update reviewNote, reviewedBy,
    // reviewedAt, result, and status. These records document store review
    // readiness only and never grant paid access or process purchases.
    match /storeTestPurchaseEvidence/{evidenceId} {
      allow read, delete: if request.auth != null && isAdmin();
      allow create: if request.auth != null
        && isAdmin()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "recorded"
        && request.resource.data.keys().hasAll(["uid", "platform", "productId", "testCase", "result", "status"])
        && ["ios", "android"].hasAny([request.resource.data.platform])
        && ["sandbox_purchase", "restore_sync", "negative_validation", "wrong_account"].hasAny([request.resource.data.testCase])
        && ["passed", "needs_review", "failed"].hasAny([request.resource.data.result]);
      allow update: if request.auth != null
        && isAdmin()
        && ["verified", "needs_review", "failed"].hasAny([request.resource.data.result])
        && ["recorded", "reviewed", "archived"].hasAny([request.resource.data.status]);
    }

    // ── Support refund readiness reviews ───────────────────────────────────
    // Manual support/refund readiness evidence queue. These records summarize
    // open support, entitlement recovery, and store evidence only. They never
    // process refunds, cancel subscriptions, write entitlements, create
    // purchases, collect payment details, bypass marketplace policy, or mark
    // paid access live.
    match /supportRefundReadinessReviews/{reviewId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["uid", "openSupportCount", "entitlementRecoveryCount", "storeEvidenceCount", "reviewScore", "status", "manualReviewOnly", "processesRefunds", "cancelsSubscriptions", "writesEntitlements", "createsPurchases", "bypassesMarketplacePolicy", "collectsPaymentDetails", "isPaidAccessLive"])
        && request.resource.data.openSupportCount >= 0
        && request.resource.data.entitlementRecoveryCount >= 0
        && request.resource.data.storeEvidenceCount >= 0
        && request.resource.data.reviewScore >= 0
        && request.resource.data.reviewScore <= 100
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.processesRefunds == false
        && request.resource.data.cancelsSubscriptions == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.bypassesMarketplacePolicy == false
        && request.resource.data.collectsPaymentDetails == false
        && request.resource.data.isPaidAccessLive == false;
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.processesRefunds == false
        && request.resource.data.cancelsSubscriptions == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.bypassesMarketplacePolicy == false
        && request.resource.data.collectsPaymentDetails == false
        && request.resource.data.isPaidAccessLive == false;
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Store review response reviews ──────────────────────────────────────
    // Manual App Review / Play review response readiness evidence. These
    // records summarize current evidence and support coverage only. They never
    // submit store review, expose private user data, include secrets, unlock
    // paid access, write entitlements, create purchases, process refunds, claim
    // review approval, mark paid access live, add tracking pixels, scrape
    // messages, or bypass marketplace policy.
    match /storeReviewResponseReviews/{reviewId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["uid", "storeEvidenceCount", "openSupportCount", "entitlementRecoveryCount", "policyLinkCount", "productCount", "reviewScore", "status", "manualReviewOnly", "submitsStoreReview", "bypassesMarketplacePolicy", "exposesPrivateUserData", "includesSecrets", "unlocksPaidAccess", "writesEntitlements", "createsPurchases", "processesRefunds", "claimsReviewApproval", "isPaidAccessLive", "hasTrackingPixels", "scrapesMessages"])
        && request.resource.data.storeEvidenceCount >= 0
        && request.resource.data.openSupportCount >= 0
        && request.resource.data.entitlementRecoveryCount >= 0
        && request.resource.data.policyLinkCount >= 0
        && request.resource.data.productCount >= 0
        && request.resource.data.reviewScore >= 0
        && request.resource.data.reviewScore <= 100
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.submitsStoreReview == false
        && request.resource.data.bypassesMarketplacePolicy == false
        && request.resource.data.exposesPrivateUserData == false
        && request.resource.data.includesSecrets == false
        && request.resource.data.unlocksPaidAccess == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.processesRefunds == false
        && request.resource.data.claimsReviewApproval == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.scrapesMessages == false;
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.submitsStoreReview == false
        && request.resource.data.bypassesMarketplacePolicy == false
        && request.resource.data.exposesPrivateUserData == false
        && request.resource.data.includesSecrets == false
        && request.resource.data.unlocksPaidAccess == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.processesRefunds == false
        && request.resource.data.claimsReviewApproval == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.scrapesMessages == false;
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Paid launch decision reviews ──────────────────────────────────────
    // Manual final paid-launch gate evidence. These records summarize current
    // products, support, recovery, and store-test evidence only. They never
    // flip paid access live, write entitlements, create purchases, process
    // payments/refunds, cancel subscriptions, collect payment details, submit
    // store review, claim launch readiness, claim sandbox proof, add tracking
    // pixels, scrape messages, or bypass marketplace policy.
    match /paidLaunchDecisionReviews/{reviewId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["uid", "productCount", "storeEvidenceCount", "passedStoreEvidenceCount", "openSupportCount", "entitlementRecoveryCount", "readyCheckCount", "totalCheckCount", "reviewScore", "status", "manualReviewOnly", "flipsPaidAccessLive", "writesEntitlements", "createsPurchases", "processesPayments", "processesRefunds", "cancelsSubscriptions", "collectsPaymentDetails", "submitsStoreReview", "bypassesMarketplacePolicy", "claimsLaunchReadiness", "claimsSandboxProof", "isPaidAccessLive", "hasTrackingPixels", "scrapesMessages"])
        && request.resource.data.productCount >= 0
        && request.resource.data.storeEvidenceCount >= 0
        && request.resource.data.passedStoreEvidenceCount >= 0
        && request.resource.data.openSupportCount >= 0
        && request.resource.data.entitlementRecoveryCount >= 0
        && request.resource.data.readyCheckCount >= 0
        && request.resource.data.totalCheckCount >= 0
        && request.resource.data.reviewScore >= 0
        && request.resource.data.reviewScore <= 100
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.flipsPaidAccessLive == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.createsPurchases == false
        && request.resource.data.processesPayments == false
        && request.resource.data.processesRefunds == false
