rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super admin check ─────────────────────────────────────────────────────
    // A document at /admins/{uid} marks that user as a super admin.
    // Super admins can read every collection — needed for future admin dashboards.
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Admins collection ─────────────────────────────────────────────────────
    // Only existing admins can read or write this collection.
    match /admins/{uid} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users read/write their own doc; admins can read all.
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;

      // Activity log — one doc per day, written and read only by the owner.
      // FIX: was missing, causing getActivityLog / saveActivity to fail.
      match /activityLog/{dateStr} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Earned badges — set when badges are awarded; read by the owner.
      // FIX: was missing, causing loadEarnedBadges / awardBadges to fail.
      match /earnedBadges/{badgeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Challenges ────────────────────────────────────────────────────────────
    // Any authenticated user can read challenges (for invite-link joins).
    // Only the creator can update/delete; admins can do anything.
    match /challenges/{challengeId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.createdBy ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
      );
      allow delete: if request.auth != null && (
        isAdmin() || request.auth.uid == resource.data.createdBy
      );

      // Members subcollection
      match /members/{uid} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == uid;

        // FIX: split create and update so we can add the admin-promotion rule.
        // A member can always update their own doc.
        // The challenge creator can also update another member's doc, but only
        // to change the 'role' field — used when promoting a new admin on leave.
        allow update: if request.auth != null && (
          request.auth.uid == uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']) &&
            get(/databases/$(database)/documents/challenges/$(challengeId)).data.createdBy == request.auth.uid
          )
        );

        allow delete: if request.auth != null && (
          request.auth.uid == uid || isAdmin()
        );

        // Daily progress logs — only the member writes; anyone authenticated can read
        match /dailyLogs/{date} {
          allow read:  if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
