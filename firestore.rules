rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super admin check ─────────────────────────────────────────────────────
    // A document at /admins/{uid} marks that user as a super admin.
    // Super admins can read every collection — needed for future admin dashboards.
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Admins collection ─────────────────────────────────────────────────────
    // Only existing admins can read or write this collection.
    match /admins/{uid} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users read/write their own doc; admins can read all and can update the
    // mirrored accountDeletionRequest review status only.
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
        && isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["accountDeletionRequest"]);

      // Activity log — one doc per day, written and read only by the owner.
      // FIX: was missing, causing getActivityLog / saveActivity to fail.
      match /activityLog/{dateStr} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Earned badges — set when badges are awarded; read by the owner.
      // FIX: was missing, causing loadEarnedBadges / awardBadges to fail.
      match /earnedBadges/{badgeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Account deletion requests ────────────────────────────────────────────
    // Users can record their own support-reviewed deletion request. Admins can
    // use reviewAccountDeletionRequest to update reviewNote, reviewedBy,
    // reviewedAt, and status. The app does not directly delete auth accounts,
    // purchase records, subscriptions, refunds, or marketplace data.
    match /accountDeletionRequests/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update: if request.auth != null
        && (
          (
            request.auth.uid == uid
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.status == "requested"
          )
          || (
            isAdmin()
            && ["requested", "contacted", "verified", "blocked", "closed"].hasAny([request.resource.data.status])
          )
        );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Support requests ─────────────────────────────────────────────────────
    // Users can create support messages for their own account. Admins can use
    // reviewSupportRequest to update reviewNote, reviewedBy, reviewedAt, and
    // status outside destructive account, refund, subscription, or entitlement
    // actions.
    match /supportRequests/{requestId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["uid", "category", "message", "status"])
        && ["general", "account", "billing", "bug", "safety"].hasAny([request.resource.data.category]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "waiting", "resolved", "closed"].hasAny([request.resource.data.status]);
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Entitlement recovery requests ───────────────────────────────────────
    // Members can ask support to review missing purchase entitlements after
    // restore/sync. Admins can use reviewEntitlementRecoveryRequest to update
    // reviewNote, reviewedBy, reviewedAt, and status. This never grants access,
    // refunds, subscriptions, purchase records, or marketplace bypasses.
    match /entitlementRecoveryRequests/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && (
          request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "productCount", "proActive", "packCount", "activePackCount", "reason", "status"])
          && request.resource.data.productCount >= 0
          && request.resource.data.packCount >= 0
          && request.resource.data.activePackCount >= 0
          && ["restore_sync_failed", "missing_pro", "missing_pack", "account_mismatch", "billing_question"].hasAny([request.resource.data.reason])
      );
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "waiting", "resolved", "closed"].hasAny([request.resource.data.status])
        ) ||
        (
          request.auth.uid == uid
          && resource.data.status == "open"
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "productCount", "proActive", "packCount", "activePackCount", "reason", "status"])
          && request.resource.data.productCount >= 0
          && request.resource.data.packCount >= 0
          && request.resource.data.activePackCount >= 0
          && ["restore_sync_failed", "missing_pro", "missing_pack", "account_mismatch", "billing_question"].hasAny([request.resource.data.reason])
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Store test purchase evidence ────────────────────────────────────────
    // Admin-only sandbox/license-test QA evidence. Admins can use
    // reviewStoreTestPurchaseEvidence to update reviewNote, reviewedBy,
    // reviewedAt, result, and status. These records document store review
    // readiness only and never grant paid access or process purchases.
    match /storeTestPurchaseEvidence/{evidenceId} {
      allow read, delete: if request.auth != null && isAdmin();
      allow create: if request.auth != null
        && isAdmin()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "recorded"
        && request.resource.data.keys().hasAll(["uid", "platform", "productId", "testCase", "result", "status"])
        && ["ios", "android"].hasAny([request.resource.data.platform])
        && ["sandbox_purchase", "restore_sync", "negative_validation", "wrong_account"].hasAny([request.resource.data.testCase])
        && ["passed", "needs_review", "failed"].hasAny([request.resource.data.result]);
      allow update: if request.auth != null
        && isAdmin()
        && ["verified", "needs_review", "failed"].hasAny([request.resource.data.result])
        && ["recorded", "reviewed", "archived"].hasAny([request.resource.data.status]);
    }

    // ── Feature submissions ─────────────────────────────────────────────────
    // Members can submit opt-in UGC for manual review. Featured submissions are
    // readable to authenticated members for Community Highlights; pending and
    // private submissions remain owner/admin only. Admin review only updates
    // status and review metadata, and does not auto-post or override consent.
    match /featureSubmissions/{submissionId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        resource.data.status == "featured" ||
        isAdmin()
      );
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.consentToFeature == true
        && request.resource.data.keys().hasAll(["uid", "displayName", "email", "instagramHandle", "category", "story", "consentToFeature", "status", "source"])
        && ["streak_win", "challenge_completion", "comeback", "beginner_win", "transformation"].hasAny([request.resource.data.category])
        && ["web", "ios", "android"].hasAny([request.resource.data.source])
        && request.resource.data.story.size() >= 20
        && request.resource.data.story.size() <= 900;
      allow update: if request.auth != null
        && isAdmin()
        && ["pending", "approved", "featured", "declined"].hasAny([request.resource.data.status]);
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Referral reward claims ───────────────────────────────────────────────
    // Users can request review for unlocked referral tiers. Admins can use
    // reviewReferralRewardClaim to update reviewNote, reviewedBy, reviewedAt,
    // and status after verifying real challenge joins before any manual
    // community recognition or future perk.
    match /referralRewardClaims/{claimId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["uid", "tierTarget", "tierLabel", "reward", "referralJoins", "status"])
        && [1, 5, 10, 25].hasAny([request.resource.data.tierTarget])
        && request.resource.data.referralJoins >= request.resource.data.tierTarget;
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        ) ||
        (
          resource.data.uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && resource.data.status == "open"
          && request.resource.data.status == "open"
          && [1, 5, 10, 25].hasAny([request.resource.data.tierTarget])
          && request.resource.data.referralJoins >= request.resource.data.tierTarget
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Creator hosting applications ─────────────────────────────────────────
    // Creators can request review for hosted challenge readiness. Admins can
    // use reviewCreatorHostingApplication to update reviewNote, reviewedBy,
    // reviewedAt, and status. This is a manual admin queue only: no contracts,
    // payouts, purchases, revenue-share, paid-access claims, or entitlements.
    match /creatorHostingApplications/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && (
          request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "specialty", "bio", "hostedCount", "memberReach", "revenueReadyCount", "status"])
          && request.resource.data.hostedCount >= 0
          && request.resource.data.memberReach >= 0
          && request.resource.data.revenueReadyCount >= 0
      );
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        ) ||
        (
          request.auth.uid == uid
          && resource.data.status == "open"
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "specialty", "bio", "hostedCount", "memberReach", "revenueReadyCount", "status"])
          && request.resource.data.hostedCount >= 0
          && request.resource.data.memberReach >= 0
          && request.resource.data.revenueReadyCount >= 0
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Creator challenge template drafts and published templates ───────────
    // Creator drafts are manual review records. Admins can publish a sanitized
    // free creator template into creatorChallengeTemplates; this does not create
    // contracts, payouts, purchases, entitlements, revenue-share, or paid-hosting
    // claims.
    match /creatorChallengeTemplateDrafts/{draftId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.keys().hasAll(["uid", "candidateChallengeName", "hostedCount", "activeHostedCount", "memberReach", "revenueReadyCount", "status"])
        && request.resource.data.hostedCount >= 0
        && request.resource.data.activeHostedCount >= 0
        && request.resource.data.memberReach >= 0
        && request.resource.data.revenueReadyCount >= 0;
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "published", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /creatorChallengeTemplates/{templateId} {
      allow read: if request.auth != null && resource.data.status == "published" && resource.data.isPublic == true;
      allow create, update, delete: if request.auth != null
        && isAdmin()
        && request.resource.data.status == "published"
        && request.resource.data.isPublic == true
        && request.resource.data.isPremium == false
        && request.resource.data.keys().hasAll(["id", "draftId", "uid", "name", "duration", "difficulty", "rules", "tasks", "disclaimer", "status", "isPublic", "isPremium"]);
    }

    match /creatorLeaderboardSnapshots/{snapshotId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.uid ||
        (resource.data.status == "published" && resource.data.isPublic == true)
      );
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.isPublic == false
        && request.resource.data.keys().hasAll(["uid", "hostedChallengeCount", "memberReach", "aggregatePoints", "topChallengeName", "status", "isPublic"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "published", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "isPublic", "reviewNote", "reviewedBy", "reviewedAt", "publishedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /creatorBrandedPages/{pageId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.uid ||
        (resource.data.status == "published" && resource.data.isPublic == true)
      );
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.isPublic == false
        && request.resource.data.keys().hasAll(["uid", "creatorSpecialty", "creatorBio", "hostedChallengeCount", "memberReach", "status", "isPublic"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "published", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "isPublic", "reviewNote", "reviewedBy", "reviewedAt", "publishedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /creatorPrivateInviteLaunches/{launchId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.isPublic == false
        && request.resource.data.keys().hasAll(["uid", "privateChallengeCount", "inviteChallengeName", "inviteReady", "status", "isPublic"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /creatorPaidHostingLaunchGateReviews/{gateId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.isPaidHostingLive == false
        && request.resource.data.keys().hasAll(["uid", "profileReady", "hostedChallengeCount", "revenueReadyCount", "hostingApplicationStatus", "launchGateReady", "status", "isPaidHostingLive"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.isPaidHostingLive == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "isPaidHostingLive", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /launchExperimentReviews/{reviewId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsAttribution == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.keys().hasAll(["uid", "recommendedExperimentLabel", "experimentScore", "campaignReach", "referralJoins", "featureSubmissionCount", "status", "manualReviewOnly", "createsAttribution", "isPaidAccessLive"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsAttribution == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "manualReviewOnly", "createsAttribution", "isPaidAccessLive", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /proTrialReviews/{reviewId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.startsTrial == false
        && request.resource.data.createsPurchase == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.keys().hasAll(["uid", "selectedReasonIds", "selectedReasonCount", "demandTotal", "topReasonLabel", "reviewScore", "status", "manualReviewOnly", "startsTrial", "createsPurchase", "writesEntitlements", "isPaidAccessLive"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.startsTrial == false
        && request.resource.data.createsPurchase == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "manualReviewOnly", "startsTrial", "createsPurchase", "writesEntitlements", "isPaidAccessLive", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /communityEventReviews/{reviewId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsTickets == false
        && request.resource.data.createsOrders == false
        && request.resource.data.collectsPayments == false
        && request.resource.data.booksVenues == false
        && request.resource.data.promisesMerch == false
        && request.resource.data.createsPartnerLinks == false
        && request.resource.data.createsPayouts == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.keys().hasAll(["uid", "selectedEventIds", "selectedEventCount", "demandTotal", "topEventLabel", "reviewScore", "status", "manualReviewOnly", "createsTickets", "createsOrders", "collectsPayments", "booksVenues", "promisesMerch", "createsPartnerLinks", "createsPayouts", "writesEntitlements"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsTickets == false
        && request.resource.data.createsOrders == false
        && request.resource.data.collectsPayments == false
        && request.resource.data.booksVenues == false
        && request.resource.data.promisesMerch == false
        && request.resource.data.createsPartnerLinks == false
        && request.resource.data.createsPayouts == false
        && request.resource.data.writesEntitlements == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "manualReviewOnly", "createsTickets", "createsOrders", "collectsPayments", "booksVenues", "promisesMerch", "createsPartnerLinks", "createsPayouts", "writesEntitlements", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    match /weeklyCampaignReviews/{reviewId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "open"
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsAttribution == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.keys().hasAll(["uid", "campaignName", "campaignWeek", "campaignHashtag", "recommendedExperimentLabel", "campaignReach", "referralJoins", "featureSubmissionCount", "status", "manualReviewOnly", "createsAttribution", "hasTrackingPixels", "isPaidAccessLive"]);
      allow update: if request.auth != null
        && isAdmin()
        && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        && request.resource.data.manualReviewOnly == true
        && request.resource.data.createsAttribution == false
        && request.resource.data.hasTrackingPixels == false
        && request.resource.data.isPaidAccessLive == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "manualReviewOnly", "createsAttribution", "hasTrackingPixels", "isPaidAccessLive", "reviewNote", "reviewedBy", "reviewedAt", "approvedAt", "updatedAt"]);
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Partner campaign applications ────────────────────────────────────────
    // Members can request manual sponsor-pilot review from first-party demand.
    // Admins can use reviewPartnerCampaignApplication to update reviewNote,
    // reviewedBy, reviewedAt, and status. This queue does not create ads,
    // tracking, partner links, purchases, or entitlements.
    match /partnerCampaignApplications/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && (
          request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "topPerkId", "topPerkLabel", "demandCount", "totalDemand", "campaignReach", "referralJoins", "status"])
          && request.resource.data.demandCount >= 0
          && request.resource.data.totalDemand >= 0
          && request.resource.data.campaignReach >= 0
          && request.resource.data.referralJoins >= 0
      );
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        ) ||
        (
          request.auth.uid == uid
          && resource.data.status == "open"
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "topPerkId", "topPerkLabel", "demandCount", "totalDemand", "campaignReach", "referralJoins", "status"])
          && request.resource.data.demandCount >= 0
          && request.resource.data.totalDemand >= 0
          && request.resource.data.campaignReach >= 0
          && request.resource.data.referralJoins >= 0
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Partner perk claims ─────────────────────────────────────────────────
    // Eligible members can request manual perk review. Admins can use
    // reviewPartnerPerkClaim to update review status plus reviewNote,
    // reviewedBy, and reviewedAt. This queue does not create coupons, partner
    // links, payouts, discounts, purchases, or entitlements.
    match /partnerPerkClaims/{claimId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (
          request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "perkId", "perkLabel", "current", "target", "status"])
          && ["gear", "recovery", "nutrition"].hasAny([request.resource.data.perkId])
          && request.resource.data.current >= request.resource.data.target
          && request.resource.data.target > 0
      );
      allow update: if request.auth != null && (
        (
          isAdmin()
          && ["open", "approved", "waiting", "not_ready", "declined"].hasAny([request.resource.data.status])
        ) ||
        (
          resource.data.uid == request.auth.uid
          && resource.data.status == "open"
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "open"
          && request.resource.data.keys().hasAll(["uid", "perkId", "perkLabel", "current", "target", "status"])
          && ["gear", "recovery", "nutrition"].hasAny([request.resource.data.perkId])
          && request.resource.data.current >= request.resource.data.target
          && request.resource.data.target > 0
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ── Challenges ────────────────────────────────────────────────────────────
    // Any authenticated user can read challenges (for invite-link joins).
    // Only the creator can update/delete; admins can do anything.
    match /challenges/{challengeId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.createdBy ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
      );
      allow delete: if request.auth != null && (
        isAdmin() || request.auth.uid == resource.data.createdBy
      );

      // Members subcollection
      match /members/{uid} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == uid;

        // FIX: split create and update so we can add the admin-promotion rule.
        // A member can always update their own doc.
        // The challenge creator can also update another member's doc, but only
        // to change the 'role' field — used when promoting a new admin on leave.
        allow update: if request.auth != null && (
          request.auth.uid == uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']) &&
            get(/databases/$(database)/documents/challenges/$(challengeId)).data.createdBy == request.auth.uid
          )
        );

        allow delete: if request.auth != null && (
          request.auth.uid == uid || isAdmin()
        );

        // Daily progress logs — only the member writes; anyone authenticated can read
        match /dailyLogs/{date} {
          allow read:  if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
